# ── Stellar Deployer ──────────────────────────────────────────────────────────
# Secret key of the Stellar account used to deploy and call the contract.
# If omitted, scripts fall back to keys/deployer_key.json (auto-generated on
# first deploy and gitignored).
DEPLOYER_SECRET=S...

# ── Contract ──────────────────────────────────────────────────────────────────
# Soroban contract ID written by deploy.js.
# If omitted, scripts fall back to keys/contract_id.txt.
CONTRACT_ID=C...

# ── Reserve top-up (topup_reserve.js only) ────────────────────────────────────
# Public key of the reserve account that testnet funds are merged into.
RESERVE=G...

# JSON array of Stellar secret keys for the temporary accounts to drain.
# Alternatively, create keys/temp_accounts.json (gitignored):
#   { "reserve": "G...", "secrets": ["S...", "S...", ...] }
TEMP_KEYS=["S...","S..."]
